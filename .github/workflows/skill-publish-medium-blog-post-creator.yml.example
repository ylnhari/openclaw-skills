# EXAMPLE — INACTIVE. This file ends in `.yml.example`, so GitHub Actions does
# NOT discover or run it. It is a ready-to-use publish workflow you can enable
# whenever you choose.
#
# To ACTIVATE:
#   1. Rename it to drop the `.example` suffix:
#      .github/workflows/skill-publish-medium-blog-post-creator.yml
#   2. Add the repository secret CLAWHUB_TOKEN (https://clawhub.ai -> API token)
#      under Settings -> Secrets and variables -> Actions.
#   3. Confirm the non-interactive auth/flags with `clawhub skill publish --help`
#      (see the note on the Publish step below).
#
# Per-skill publish workflow for ClawHub. Workflows must live at the repo root
# (<repo-root>/.github/workflows/) — GitHub Actions does not discover files
# nested inside skills/.
#
# When adding a new skill, copy this file to
#   .github/workflows/skill-publish-<skill-slug>.yml.example
# and adjust: workflow `name:`, the tag pattern, `SKILL_DIR`, `SLUG`, `SKILL_NAME`.

name: Publish medium-blog-post-creator to ClawHub

on:
  workflow_dispatch:
    inputs:
      version:
        description: 'Explicit semver (e.g. 1.1.0). Leave empty to auto-bump patch.'
        required: false
        default: ''
        type: string
      dry_run:
        description: 'Run without uploading.'
        required: false
        default: 'true'
        type: choice
        options:
          - 'true'
          - 'false'
  # Auto-trigger on a tagged release. Adjust tag pattern when changing the slug.
  push:
    tags:
      - 'v-medium-blog-post-creator-*'

jobs:
  publish:
    runs-on: ubuntu-latest
    permissions:
      contents: read
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Set up Node
        uses: actions/setup-node@v4
        with:
          node-version: '20'

      - name: Install ClawHub CLI
        run: npm install -g clawhub

      # ClawHub reads its publish credential from the CLAWHUB_TOKEN
      # environment variable for non-interactive (CI) publishing, so no
      # separate login step is needed here.
      # NOTE: confirm the exact non-interactive auth for your clawhub
      # version with `clawhub login --help` / `clawhub skill publish --help`
      # before the first real publish. The maintainer can also publish
      # manually from a logged-in shell instead of relying on this workflow.
      - name: Publish skill
        env:
          CLAWHUB_TOKEN: ${{ secrets.CLAWHUB_TOKEN }}
          SKILL_DIR: skills/medium-blog-post-creator
          SLUG: medium-blog-post-creator
          SKILL_NAME: "Medium Blog Post Creator"
          VERSION: ${{ github.event.inputs.version }}
          DRY_RUN: ${{ github.event.inputs.dry_run }}
        run: |
          set -euo pipefail

          ARGS=(skill publish "./${SKILL_DIR}" \
            --slug "${SLUG}" \
            --name "${SKILL_NAME}" \
            --changelog "Auto-publish from ${GITHUB_REF}")

          if [ -n "${VERSION}" ]; then
            ARGS+=(--version "${VERSION}")
          fi

          if [ "${DRY_RUN}" = "true" ]; then
            ARGS+=(--dry-run)
          fi

          clawhub "${ARGS[@]}"
